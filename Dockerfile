# Используем маленький базовый образ Alpine Linux
FROM alpine:latest

# Устанавливаем microsocks
# microsocks может не быть в стандартных репо, возможно, придется компилировать или искать готовый пакет.
# Проверим, есть ли он в apk (самый простой путь)
RUN apk update && apk add --no-cache microsocks

# Если apk add не сработает, возможно, понадобится более сложная установка (компиляция),
# но пока попробуем так.

# Задаем переменные окружения для имени пользователя и пароля.
# Render позволит установить их значения при деплое.
# НЕ УКАЗЫВАЙ ЗДЕСЬ РЕАЛЬНЫЕ ПАРОЛИ!
ENV PROXY_USER="survivor"
ENV PROXY_PASSWORD="Some##heavYShit45%"

# Стандартный порт для SOCKS - 1080
EXPOSE 1080

# Команда для запуска microsocks с аутентификацией по имени/паролю
# Он будет слушать на порту 1080 и требовать учетные данные из переменных окружения.
CMD ["microsocks", "-p", "1080", "-u", "$PROXY_USER", "-P", "$PROXY_PASSWORD"]